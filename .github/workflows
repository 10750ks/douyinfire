name: Douyin Fire Keeper

on:
  workflow_dispatch:
  schedule:
    # GitHub Actions uses UTC. 16:10 UTC = 00:10 China time.
    - cron: "10 16 * * *"

jobs:
  run:
    runs-on: ubuntu-latest
    timeout-minutes: 20

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: |
          python -m pip install -r requirements.txt
          python -m playwright install --with-deps chromium

      - name: Run
        run: python douyin_fire_keeper.py --config config.json run
